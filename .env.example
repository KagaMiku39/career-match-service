# Copy this file to .env if you want to configure a real LLM provider.
# Do not commit .env to GitHub.

# Database:
# Leave DATABASE_URL empty to use local SQLite: data/analysis.db
# Use this format to switch to MySQL:
# DATABASE_URL=mysql+pymysql://career_user:career_password@127.0.0.1:3306/career_match
DATABASE_URL=

# Zhipu AI example:
LLM_API_KEY=replace_with_your_api_key
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
LLM_MODEL=glm-5.2
